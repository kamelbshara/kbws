generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SYSTEM_ADMIN
  PRINCIPAL
  VICE_PRINCIPAL
  TEAM_LEADER
  TEACHER
  INITIATIVE_OWNER
}

enum Track {
  GENERAL
  ADVANCED
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum LessonPlanStatus {
  DRAFT
  PRINTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum InsightScope {
  TEACHER
  SCHOOL
}

enum InitiativeStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum InitiativeCategory {
  EDUCATIONAL
  COMMUNITY
  NATIONAL
  INNOVATION
  HEALTH_SAFETY
  OTHER
}

enum TeamType {
  ACADEMIC
  QUALITY
  INITIATIVE
  ADMINISTRATIVE
  SUPPORT
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum OperationalPlanLevel {
  TEAM
  SCHOOL
}

enum QuestionType {
  MULTIPLE_CHOICE
  OPEN
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  ADVANCED
  CHALLENGE
}

model School {
  id            String         @id @default(cuid())
  name          String
  nameAr        String
  address       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  users            User[]
  academicYears    AcademicYear[]
  classSections    ClassSection[]
  timetables       Timetable[]
  initiatives      Initiative[]
  teams            Team[]
  operationalPlans OperationalPlan[]
  insights         Insight[]
}

model AcademicYear {
  id                 String               @id @default(cuid())
  schoolId           String
  school             School               @relation(fields: [schoolId], references: [id])
  name               String
  startDate          DateTime
  endDate            DateTime
  isActive           Boolean              @default(false)
  createdAt          DateTime             @default(now())

  classSections      ClassSection[]
  timetables         Timetable[]
  teacherAssignments TeacherAssignment[]

  @@unique([schoolId, name])
}

model Grade {
  id                 String              @id @default(cuid())
  level              Int                 @unique
  name               String
  nameAr             String

  classSections      ClassSection[]
  curriculumContents CurriculumContent[]
  questionBankItems  QuestionBankItem[]
}

model ClassSection {
  id             String       @id @default(cuid())
  schoolId       String
  school         School       @relation(fields: [schoolId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  gradeId        String
  grade          Grade        @relation(fields: [gradeId], references: [id])
  track          Track?
  name           String
  createdAt      DateTime     @default(now())

  teacherAssignments TeacherAssignment[]
  timetables         Timetable[]
  lessonPlans        LessonPlan[]

  @@unique([academicYearId, gradeId, name])
}

model Subject {
  id     String @id @default(cuid())
  name   String
  nameAr String
  code   String @unique

  teacherAssignments TeacherAssignment[]
  timetables         Timetable[]
  curriculumContents CurriculumContent[]
  questionBankItems  QuestionBankItem[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  nameAr       String?
  role         Role
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacherAssignments TeacherAssignment[]
  timetableSlots     Timetable[]         @relation("TimetableTeacher")
  lessonPlans        LessonPlan[]
  aiGenerationLogs   AIGenerationLog[]
  auditLogs          AuditLog[]
  printedVersions    LessonPlanVersion[]
  ownedInitiatives   Initiative[]
  initiativeEvidence InitiativeEvidence[]
  ledTeams           Team[]               @relation("TeamLeader")
  teamMemberships    TeamMember[]
  meetingsCreated    Meeting[]
  actionItems        ActionItem[]
  createdQuestions   QuestionBankItem[]
  assessments        Assessment[]
  requestedInsights  Insight[]
}

model TeacherAssignment {
  id             String       @id @default(cuid())
  teacherId      String
  teacher        User         @relation(fields: [teacherId], references: [id])
  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id])
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([teacherId, classSectionId, subjectId, academicYearId])
}

model Timetable {
  id             String       @id @default(cuid())
  schoolId       String
  school         School       @relation(fields: [schoolId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id])
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id])
  teacherId      String
  teacher        User         @relation("TimetableTeacher", fields: [teacherId], references: [id])
  dayOfWeek      DayOfWeek
  periodNumber   Int
  startTime      String?
  endTime        String?

  lessonPlans    LessonPlan[]

  @@unique([classSectionId, dayOfWeek, periodNumber, academicYearId])
  @@unique([teacherId, dayOfWeek, periodNumber, academicYearId])
}

model CurriculumContent {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  gradeId     String
  grade       Grade    @relation(fields: [gradeId], references: [id])
  track       Track?
  unit        String
  unitTitle   String
  lessonTitle String
  orderIndex  Int      @default(0)

  learningOutcomes LearningOutcome[]
  lessonPlans      LessonPlan[]

  @@index([subjectId, gradeId, track])
}

model LearningOutcome {
  id                  String            @id @default(cuid())
  curriculumContentId String
  curriculumContent   CurriculumContent @relation(fields: [curriculumContentId], references: [id])
  textAr              String
  textEn              String
  skill               String

  lessonPlans LessonPlan[]
}

model LessonPlan {
  id                    String            @id @default(cuid())
  teacherId             String
  teacher               User              @relation(fields: [teacherId], references: [id])
  timetableId           String?
  timetable             Timetable?        @relation(fields: [timetableId], references: [id])
  classSectionId        String
  classSection          ClassSection      @relation(fields: [classSectionId], references: [id])
  curriculumContentId   String
  curriculumContent     CurriculumContent @relation(fields: [curriculumContentId], references: [id])
  learningOutcomeId     String
  learningOutcome       LearningOutcome   @relation(fields: [learningOutcomeId], references: [id])
  outcomeOverrideText   String?
  outcomeOverrideReason String?
  lessonDate            DateTime
  durationMinutes       Int               @default(45)
  teacherPrompt         String
  strategies            String[]
  tools                 String[]
  contentJson           Json?
  status                LessonPlanStatus  @default(DRAFT)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  versions         LessonPlanVersion[]
  aiGenerationLogs AIGenerationLog[]
  assessments      Assessment[]
}

model LessonPlanVersion {
  id            String     @id @default(cuid())
  lessonPlanId  String
  lessonPlan    LessonPlan @relation(fields: [lessonPlanId], references: [id])
  versionNumber Int
  contentJson   Json
  pdfPath       String?
  printedAt     DateTime   @default(now())
  printedById   String
  printedBy     User       @relation(fields: [printedById], references: [id])

  @@unique([lessonPlanId, versionNumber])
}

model AIGenerationLog {
  id                String           @id @default(cuid())
  lessonPlanId      String?
  lessonPlan        LessonPlan?      @relation(fields: [lessonPlanId], references: [id])
  initiativeId      String?
  initiative        Initiative?      @relation(fields: [initiativeId], references: [id])
  operationalPlanId String?
  operationalPlan   OperationalPlan? @relation(fields: [operationalPlanId], references: [id])
  assessmentId      String?
  assessment        Assessment?      @relation(fields: [assessmentId], references: [id])
  insightId         String?
  insight           Insight?         @relation(fields: [insightId], references: [id])
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  section           String?
  model             String
  promptInput       Json
  responseJson      Json?
  status            String
  errorMessage      String?
  createdAt         DateTime         @default(now())
}

model Team {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String
  type      TeamType
  goal      String?
  leaderId  String
  leader    User     @relation("TeamLeader", fields: [leaderId], references: [id])
  createdAt DateTime @default(now())

  members         TeamMember[]
  meetings        Meeting[]
  operationalPlan OperationalPlan?
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  team     Team     @relation(fields: [teamId], references: [id])
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
}

model Meeting {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  title       String
  date        DateTime
  agenda      String?
  minutes     String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  actionItems ActionItem[]
}

model ActionItem {
  id        String            @id @default(cuid())
  meetingId String
  meeting   Meeting           @relation(fields: [meetingId], references: [id])
  task      String
  ownerId   String
  owner     User              @relation(fields: [ownerId], references: [id])
  dueDate   DateTime?
  status    ActionItemStatus  @default(OPEN)
  createdAt DateTime          @default(now())
}

model OperationalPlan {
  id        String               @id @default(cuid())
  teamId    String?              @unique
  team      Team?                @relation(fields: [teamId], references: [id])
  schoolId  String?
  school    School?              @relation(fields: [schoolId], references: [id])
  level     OperationalPlanLevel
  title     String
  initialIdea String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  items            OperationalPlanItem[]
  aiGenerationLogs AIGenerationLog[]
}

model OperationalPlanItem {
  id                String          @id @default(cuid())
  operationalPlanId String
  operationalPlan   OperationalPlan @relation(fields: [operationalPlanId], references: [id])
  orderIndex        Int             @default(0)
  domain            String
  objective         String
  actions           String
  responsible       String?
  timeline          String?
  indicator         String?
  evidence          String?
  risk              String?
}

model Initiative {
  id           String              @id @default(cuid())
  ownerId      String
  owner        User                @relation(fields: [ownerId], references: [id])
  schoolId     String
  school       School              @relation(fields: [schoolId], references: [id])
  title        String
  category     InitiativeCategory
  initialIdea  String
  goal         String?
  targetGroup  String?
  baseline     String?
  status       InitiativeStatus    @default(DRAFT)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  phases           InitiativePhase[]
  indicators       InitiativeIndicator[]
  evidence         InitiativeEvidence[]
  aiGenerationLogs AIGenerationLog[]
}

model InitiativePhase {
  id           String     @id @default(cuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id])
  orderIndex   Int        @default(0)
  name         String
  description  String
  timeline     String?
  responsible  String?
}

model InitiativeIndicator {
  id                String     @id @default(cuid())
  initiativeId      String
  initiative        Initiative @relation(fields: [initiativeId], references: [id])
  name              String
  measurementMethod String
  targetValue       String?
  actualValue       String?
}

model InitiativeEvidence {
  id           String     @id @default(cuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id])
  description  String
  link         String?
  createdAt    DateTime   @default(now())
  createdById  String
  createdBy    User       @relation(fields: [createdById], references: [id])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  module     String
  entityId   String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime    @default(now())
}

model PermissionGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  roles     Role[]
  updatedAt DateTime @updatedAt
}

model Insight {
  id              String       @id @default(cuid())
  scope           InsightScope
  schoolId        String
  school          School       @relation(fields: [schoolId], references: [id])
  requestedById   String
  requestedBy     User         @relation(fields: [requestedById], references: [id])
  summary         String
  strengths       Json
  concerns        Json
  recommendations Json
  createdAt       DateTime     @default(now())

  aiGenerationLogs AIGenerationLog[]

  @@index([scope, schoolId, requestedById])
}

model QuestionBankItem {
  id             String             @id @default(cuid())
  subjectId      String
  subject        Subject            @relation(fields: [subjectId], references: [id])
  gradeId        String
  grade          Grade              @relation(fields: [gradeId], references: [id])
  skill          String
  difficulty     QuestionDifficulty
  type           QuestionType
  questionText   String
  choices        Json?
  correctAnswer  String
  explanation    String?
  createdById    String
  createdBy      User               @relation(fields: [createdById], references: [id])
  createdAt      DateTime           @default(now())

  assessmentQuestions AssessmentQuestion[]

  @@index([subjectId, gradeId, skill])
}

model Assessment {
  id             String      @id @default(cuid())
  teacherId      String
  teacher        User        @relation(fields: [teacherId], references: [id])
  lessonPlanId   String?
  lessonPlan     LessonPlan? @relation(fields: [lessonPlanId], references: [id])
  title          String
  createdAt      DateTime    @default(now())

  questions        AssessmentQuestion[]
  aiGenerationLogs AIGenerationLog[]
}

model AssessmentQuestion {
  id            String           @id @default(cuid())
  assessmentId  String
  assessment    Assessment       @relation(fields: [assessmentId], references: [id])
  questionId    String
  question      QuestionBankItem @relation(fields: [questionId], references: [id])
  orderIndex    Int              @default(0)

  @@unique([assessmentId, questionId])
}
