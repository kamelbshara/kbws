# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/kbws"

# Auth.js secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Base URL of the app (used by Auth.js)
NEXTAUTH_URL="http://localhost:3000"

# OpenAI API key for lesson plan generation
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional: path to a local Chromium binary for PDF generation in development.
# Leave unset in production — @sparticuz/chromium supplies the binary there.
# PUPPETEER_EXECUTABLE_PATH="/path/to/chromium"

# Cloud file storage for initiative evidence uploads. Without this set, uploads
# fall back to writing under public/uploads, which only works in local dev —
# Vercel's serverless filesystem is ephemeral, so this MUST be set in production.
# Create a Blob store from the Vercel dashboard (Storage tab) and it will offer
# to inject this automatically into your project's env vars.
BLOB_READ_WRITE_TOKEN=""

# Optional: outbound email (password reset, message notifications) via Resend.
# Without this set, emails are logged to the server console instead of sent —
# fine for local dev, not usable for a real deployment that needs to actually
# deliver password-reset emails.
RESEND_API_KEY=""
