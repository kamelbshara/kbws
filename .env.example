# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/kbws"

# Auth.js secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Base URL of the app (used by Auth.js)
NEXTAUTH_URL="http://localhost:3000"

# OpenAI API key for lesson plan generation
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional: path to a local Chromium binary for PDF generation in development.
# Leave unset in production — @sparticuz/chromium supplies the binary there.
# PUPPETEER_EXECUTABLE_PATH="/path/to/chromium"
